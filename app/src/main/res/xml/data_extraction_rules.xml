<?xml version="1.0" encoding="utf-8"?>
<!-- API 31+ -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="nossasaude.db"/>
        <exclude domain="database" path="nossasaude.db-shm"/>
        <exclude domain="database" path="nossasaude.db-wal"/>
        <exclude domain="file" path="images"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="nossasaude.db"/>
        <exclude domain="database" path="nossasaude.db-shm"/>
        <exclude domain="database" path="nossasaude.db-wal"/>
        <exclude domain="file" path="images"/>
    </device-transfer>
</data-extraction-rules>
